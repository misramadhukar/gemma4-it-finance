# Copy this file to gcp/config.env and edit the values.

PROJECT_ID=your-gcp-project-id
ZONE=asia-south1-a
VM_NAME=gemma4-finance-ft
MACHINE_TYPE=g2-standard-8

BOOT_DISK_SIZE=200GB
BOOT_DISK_TYPE=pd-balanced
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud

# STANDARD is recommended for the first successful run. SPOT is cheaper but can
# stop at any time; checkpoints allow training to resume.
PROVISIONING_MODEL=STANDARD

# Directory below the VM user's home directory.
REMOTE_DIR=fine_tune

# TensorBoard port forwarded over SSH.
TENSORBOARD_PORT=6006
