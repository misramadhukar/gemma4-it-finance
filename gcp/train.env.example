# Copy this file to gcp/train.env on the VM and edit as needed.

MODEL_ID=google/gemma-4-E2B-it
MODEL_REVISION=main
DATASET_ID=kdave/Indian_Financial_News
DATASET_REVISION=main
DATASET_SPLIT=train
OUTPUT_DIR=outputs/gemma4-e2b-finance-qlora

LIMIT=5000
TEST_SIZE=0.1
SEED=42
MAX_LENGTH=1024
EPOCHS=3
LEARNING_RATE=1e-4
TRAIN_BATCH_SIZE=1
EVAL_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=8

LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGETS=all-linear

SAVE_STEPS=100
SAVE_TOTAL_LIMIT=3
LOGGING_STEPS=10
DATALOADER_WORKERS=2

# Leave empty for a new run. Set to latest after an interruption.
RESUME_FROM_CHECKPOINT=
OVERWRITE_OUTPUT_DIR=false

# Set PUSH_TO_HUB=true and fill HUB_MODEL_ID only when upload is required.
PUSH_TO_HUB=false
HUB_MODEL_ID=

# Generated-output evaluation. Set threshold values before a release candidate.
EVAL_MAX_EXAMPLES=200
MIN_SENTIMENT_ACCURACY=
MIN_SENTIMENT_PARSE_RATE=
MIN_ROUGE_L=

TMUX_SESSION=gemma4

# Cost control. The wrapper writes outputs/training_job_status.json, sends the
# optional notification, then powers off the VM. The boot disk and outputs are
# preserved. Start the VM again from Cloud Shell to retrieve or evaluate them.
AUTO_SHUTDOWN=true
SHUTDOWN_ON_FAILURE=true
AUTO_SHUTDOWN_DELAY_MINUTES=1

# Optional HTTPS webhook. For the simplest phone/browser notification, create a
# private random ntfy topic and use https://ntfy.sh/YOUR_RANDOM_TOPIC.
# Other supported kinds are slack, discord, and generic JSON.
NOTIFICATION_KIND=ntfy
NOTIFICATION_URL=

# Keep false for normal operation. This exists only for controlled debugging.
SKIP_READINESS_CHECKS=false
